{
  "name": "ghost-shift",
  "private": true,
  "version": "0.1.0",
  "description": "A live pixel office for OpenClaw and other agent backends.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xmu-csnoob/openclaw-ghost-shift.git"
  },
  "homepage": "https://github.com/xmu-csnoob/openclaw-ghost-shift#readme",
  "bugs": {
    "url": "https://github.com/xmu-csnoob/openclaw-ghost-shift/issues"
  },
  "keywords": [
    "openclaw",
    "agents",
    "pixel-art",
    "react",
    "golang"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "build": "tsc -b && node ./scripts/build.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:backend": "cd server && go test ./...",
    "test:backend:coverage": "cd server && go test ./... -coverprofile=coverage.out && go tool cover -func=coverage.out",
    "preview": "vite preview",
    "proxy:local": "node ./scripts/local-proxy.mjs"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.1.0",
    "ws": "^8.19.0"
  }
}
