}

.gs-dashboard-compare__bar--today {
  background: linear-gradient(180deg, var(--gs-accent-primary), rgba(var(--gs-accent-primary-rgb), 0.18));
}

.gs-dashboard-compare__bar--yesterday {
  background: linear-gradient(180deg, var(--gs-accent-secondary), rgba(var(--gs-accent-secondary-rgb), 0.18));
}

.gs-dashboard-compare__label {
  font-size: 0.68rem;
  color: rgba(221, 230, 243, 0.54);
}

.gs-dashboard-card__skeleton {
  border-radius: 0;
}

.gs-dashboard-card__skeleton--title {
  width: 42%;
  height: 10px;
}

.gs-dashboard-card__skeleton--value {
  width: 58%;
  height: 28px;
  margin-top: 14px;
}

.gs-dashboard-card__skeleton--meta {
  width: 76%;
  height: 10px;
  margin-top: 12px;
}

.gs-dashboard-compare__skeleton {
  height: 188px;
  margin-top: 18px;
}

.gs-dashboard-visual__head strong {
  font-size: 0.96rem;
  color: #f4f6fb;
}

.gs-dashboard-chart,
.gs-dashboard-radar {
  width: 100%;
  margin-top: 16px;
}

.gs-dashboard-chart__grid,
.gs-dashboard-radar__ring,
.gs-dashboard-radar__axis {
  fill: none;
  stroke: rgba(221, 230, 243, 0.12);
  stroke-width: 1;
}

.gs-dashboard-chart__actual {
  fill: none;
  stroke: var(--gs-accent-primary);
  stroke-width: 3;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.gs-dashboard-chart__forecast {
  fill: none;
  stroke: var(--gs-accent-secondary);
  stroke-width: 3;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-dasharray: 6 6;
}

.gs-dashboard-chart__dot,
.gs-dashboard-radar__shape {
  animation: gs-rise 0.4s ease both;
}

.gs-dashboard-chart__dot {
  transition:
    cx 0.32s ease,
    cy 0.32s ease,
    r 0.24s ease;
}

.gs-dashboard-chart__dot--forecast {
  fill: var(--gs-accent-secondary);
}

.gs-dashboard-radar {
  max-width: 360px;
}

.gs-dashboard-radar__shape {
  fill: rgba(var(--gs-accent-primary-rgb), 0.18);
  stroke: var(--gs-accent-primary);
  stroke-width: 2;
}

.gs-dashboard-radar__label {
  font-size: 0.68rem;
  fill: rgba(221, 230, 243, 0.72);
  text-anchor: middle;
}

.gs-dashboard-radar__legend {
  display: flex;
  flex-wrap: wrap;
  gap: 10px 14px;
  margin-top: 14px;
  color: rgba(221, 230, 243, 0.76);
  font-size: 0.82rem;
}

.gs-share-layout,
.gs-case-study__layout {
  display: grid;
  grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
  gap: 18px;
  margin-top: 18px;
}

.gs-share-style-grid,
.gs-share-platform-grid,
.gs-case-study__timeline,
.gs-case-study__interactive,
.gs-case-study__field-detail {
  display: grid;
  gap: 14px;
}

.gs-share-theme-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.gs-share-style-group,
.gs-share-field {
  display: grid;
  gap: 10px;
}

.gs-share-field input,
.gs-share-field textarea {
  width: 100%;
  padding: 12px 14px;
  border: 1px solid rgba(159, 192, 255, 0.18);
  background: rgba(8, 14, 22, 0.86);
  color: #e2e9f5;
  font: inherit;
}

.gs-share-field textarea {
  resize: vertical;
  min-height: 96px;
}

.gs-share-platform-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 16px;
}

.gs-share-platform-card {
  padding: 14px;
  border: 1px solid rgba(159, 192, 255, 0.14);
  background: rgba(11, 20, 34, 0.72);
}

.gs-share-platform-card span {
  display: block;
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(221, 230, 243, 0.56);
}

.gs-share-platform-card strong {
  display: block;
  margin-top: 8px;
  color: #f4f6fb;
}

.gs-share-platform-card.is-good {
  border-color: rgba(var(--gs-accent-tertiary-rgb), 0.2);
}

.gs-share-platform-card.is-warn {
  border-color: rgba(var(--gs-accent-secondary-rgb), 0.28);
}

.gs-share-preview img {
  width: 100%;
  border: 1px solid rgba(159, 192, 255, 0.14);
  display: block;
}

.gs-case-study__layout {
  align-items: start;
}

.gs-case-study__timeline-track {
  position: relative;
  height: 8px;
  border-radius: 0;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.08);
}

.gs-case-study__timeline-progress {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, var(--gs-accent-primary), var(--gs-accent-secondary));
  transition: width 0.35s ease;
}

.gs-case-study__timeline-meta span {
  color: rgba(221, 230, 243, 0.72);
  font-size: 0.9rem;
}

.gs-case-study__timeline-meta button,
.gs-faq__trigger {
  min-height: 40px;
  padding: 0 12px;
}

.gs-case-study__example pre {
  margin-top: 14px;
  white-space: pre-wrap;
  word-break: break-word;
  font-family: 'Azeret Mono', 'SFMono-Regular', monospace;
  font-size: 0.82rem;
  line-height: 1.7;
  color: #e6ecf6;
}

.gs-case-study__tabs button.is-active {
  background: rgba(var(--gs-accent-primary-rgb), 0.14);
  border-color: rgba(var(--gs-accent-primary-rgb), 0.48);
}

.gs-case-study__panel {
  margin-top: 14px;
}

.gs-case-study__mask-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 14px;
}

.gs-case-study__mask-grid span {
  padding: 8px 10px;
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.gs-case-study__mask-grid .is-hidden {
  background: rgba(var(--gs-accent-danger-rgb), 0.12);
  color: var(--gs-accent-danger);
}

.gs-case-study__mask-grid .is-visible {
  background: rgba(var(--gs-accent-tertiary-rgb), 0.12);
  color: var(--gs-accent-tertiary);
}

.gs-case-study__surface-card {
  display: grid;
  gap: 8px;
  margin-top: 14px;
  padding: 16px;
  border: 1px solid rgba(159, 192, 255, 0.14);
  background: rgba(11, 20, 34, 0.72);
}

.gs-case-study__surface-card strong {
  color: #f4f6fb;
  font-size: 1.05rem;
}

.gs-case-study__surface-card span {
  color: rgba(221, 230, 243, 0.74);
}

.gs-case-study__stack {
  display: grid;
  gap: 18px;
}

.gs-case-study__field-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.gs-case-study__field-grid button {
  display: grid;
  justify-items: start;
  gap: 6px;
  min-height: 96px;
  padding: 14px;
  text-align: left;
  transition:
    transform 0.2s ease,
    border-color 0.2s ease,
    background 0.2s ease;
}

.gs-case-study__field-grid button:hover {
  transform: translateY(-1px);
}

.gs-case-study__field-grid button span,
.gs-case-study__field-detail span {
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(221, 230, 243, 0.56);
}

.gs-case-study__field-grid button strong {
  color: #f4f6fb;
  font-size: 0.94rem;
  line-height: 1.45;
}

.gs-case-study__field-detail {
  padding: 16px;
  border: 1px solid rgba(159, 192, 255, 0.14);
  background: rgba(11, 20, 34, 0.72);
}

.gs-faq {
  display: grid;
  gap: 12px;
}

.gs-faq__item {
  padding: 14px 16px;
  border: 1px solid rgba(159, 192, 255, 0.14);
  background: rgba(9, 15, 24, 0.78);
}

.gs-faq__item.is-open {
  border-color: rgba(var(--gs-accent-primary-rgb), 0.28);
}

.gs-faq__trigger {
  width: 100%;
  justify-content: space-between;
  cursor: pointer;
  font-weight: 600;
  color: #f4f6fb;
}

@keyframes gs-hover-card-rise {
  from {
    opacity: 0;
    transform: translate3d(0, 8px, 0);
  }

  to {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
}

@keyframes gs-status-pulse {
  0%,
  100% {
    box-shadow: 0 0 0 0 rgba(155, 255, 180, 0.12);
  }

  50% {
    box-shadow: 0 0 0 8px rgba(155, 255, 180, 0.02);
  }
}

@keyframes gs-shimmer {
  to {
    transform: translateX(100%);
  }
}

@keyframes gs-hover-sheen {
  to {
    background-position: -200% 0;
  }
}

@keyframes gs-wave {
  0%,
  100% {
    opacity: 0.62;
    transform: scaleY(0.92);
  }

  50% {
    opacity: 1;
    transform: scaleY(1);
  }
}

@keyframes gs-bar-rise {
  from {
    opacity: 0;
    transform: scaleY(0.55);
  }

  to {
    opacity: 1;
    transform: scaleY(1);
  }
}

@keyframes gs-page-fade {
  from {
    opacity: 0;
    transform: translateY(10px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.gs-embed-shell {
  min-height: 100vh;
  display: grid;
  place-items: center;
  padding: 24px;
  background:
    radial-gradient(circle at top, rgba(246, 201, 120, 0.14), transparent 28%),
    linear-gradient(180deg, #09121f 0%, #070d16 100%);
}

@keyframes gs-rise {
  from {
    opacity: 0;
    transform: translateY(18px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (max-width: 980px) {
  .gs-app-nav {
    align-items: flex-start;
    flex-direction: column;
  }

  .gs-app-nav__links {
    width: 100%;
    justify-content: flex-start;
  }

  .gs-hero,
  .gs-demo-layout,
  .gs-docs-layout,
  .gs-share-layout,
  .gs-case-study__layout {
    grid-template-columns: 1fr;
  }

  .gs-surface-grid,
  .gs-case-grid,
  .gs-route-grid {
    grid-template-columns: 1fr;
  }

  .gs-dashboard-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .gs-surface-card--featured {
    grid-column: span 1;
  }
}

@media (max-width: 720px) {
  .gs-app-nav,
  .gs-breadcrumbs {
    width: min(calc(100vw - 20px), 1200px);
  }

  .gs-app-nav {
    padding-top: 14px;
  }

  .gs-app-nav__logo {
    width: 36px;
    height: 36px;
  }

  .gs-app-nav__link {
    flex: 1 1 120px;
    justify-content: center;
    text-align: center;
  }

  .gs-page {
    width: min(calc(100vw - 20px), 1200px);
    padding: 18px 0 56px;
  }

  .gs-hero-copy,
  .gs-demo-copy,
  .gs-docs-copy,
  .gs-dashboard-section,
  .gs-share-section,
  .gs-summary-card,
  .gs-surface-card,
  .gs-side-card,
  .gs-case-card,
  .gs-code-card,
  .gs-case-study__example,
  .gs-dashboard-card,
  .gs-dashboard-compare,
  .gs-share-card,
  .gs-share-preview {
    padding: 18px;
  }

  .gs-hero h1,
  .gs-demo-copy h2,
  .gs-case-study h2,
  .gs-docs-copy h2 {
    line-height: 1;
  }

  .gs-summary-card__topline,
  .gs-summary-card__footer,
  .gs-dashboard-head,
  .gs-share-section__head,
  .gs-dashboard-compare__head {
    align-items: flex-start;
    flex-direction: column;
  }

  .gs-summary-card__metrics,
  .gs-summary-card__facts,
  .gs-summary-card__sparkline-grid,
  .gs-dashboard-grid,
  .gs-route-grid--compact {
    grid-template-columns: 1fr;
  }

  .gs-dashboard-card--trend {
    grid-column: span 1;
  }

  .gs-dashboard-compare__chart {
    gap: 4px;
    min-height: 150px;
    overflow-x: auto;
    padding-bottom: 6px;
  }

  .gs-summary-card__carousel-actions button,
  .gs-share-card__actions button,
  .gs-case-study__tabs button {
    min-height: 44px;
    flex: 1 1 140px;
  }

  .gs-demo-stage {
    height: 420px;
  }

  .gs-stage-topbar {
    right: 62px;
  }

  .gs-stage-panel {
    min-height: 34px;
    padding: 0 10px;
    font-size: 0.78rem;
  }

  .gs-stage-panel--stats {
    width: 100%;
    justify-content: space-between;
  }

  .gs-stage-heatmap-legend {
    right: 14px;
    max-width: none;
  }

  .gs-stage-help,
  .gs-stage-roster {
    display: none;
  }

  .gs-stage-zoom button,
  .gs-stage-zoom span {
    width: 34px;
    height: 34px;
  }

  .gs-share-card__meta {
    align-items: flex-start;
    flex-direction: column;
  }

  .gs-replay-bar__preview-grid,
  .gs-replay-bar__events {
    scrollbar-width: none;
  }

  .gs-replay-bar__preview-grid::-webkit-scrollbar,
  .gs-replay-bar__events::-webkit-scrollbar {
    display: none;
  }
}

/* Help button */
.gs-help-button {
  display: grid;
  place-items: center;
  width: 36px;
  height: 36px;
  border: 1px solid rgba(159, 192, 255, 0.32);
  border-radius: 50%;
  background: rgba(125, 179, 255, 0.12);
  color: #c8d6f5;
  font-size: 1.1rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s ease;
}

.gs-help-button:hover {
  background: rgba(125, 179, 255, 0.24);
  border-color: rgba(159, 192, 255, 0.48);
  color: #f4f6fb;
  transform: scale(1.05);
}

.gs-help-button:active {
  transform: scale(0.98);
}

/* Help Modal */
.gs-help-modal .gs-modal {
  width: min(95vw, 1100px);
  max-height: 90vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.gs-help-modal .gs-modal__content {
  overflow-y: auto;
  padding: 0;
  flex: 1;
}

.gs-help-modal .gs-case-study {
  padding: 24px;
  margin: 0;
}

.gs-help-modal .gs-case-study__head {
  margin-bottom: 20px;
}
