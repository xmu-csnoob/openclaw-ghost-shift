.gs-router-shell {
  min-height: 100vh;
}

.gs-app-nav,
.gs-breadcrumbs {
  position: relative;
  z-index: 3;
  width: min(1200px, calc(100vw - 32px));
  margin: 0 auto;
}

.gs-app-nav {
  position: sticky;
  top: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
  padding: 18px 0 12px;
  backdrop-filter: blur(18px);
}

.gs-app-nav__brand {
  display: flex;
  align-items: center;
  gap: 12px;
}

.gs-app-nav__logo {
  display: grid;
  place-items: center;
  width: 40px;
  height: 40px;
  border: 1px solid rgba(159, 192, 255, 0.24);
  background: linear-gradient(135deg, rgba(246, 201, 120, 0.18), rgba(125, 179, 255, 0.16));
  color: #f4f6fb;
  font-family: 'Azeret Mono', 'SFMono-Regular', monospace;
  font-size: 0.84rem;
  letter-spacing: 0.12em;
}

.gs-app-nav__title {
  font-size: 0.96rem;
  font-weight: 700;
  color: #f4f6fb;
}

.gs-app-nav__subtitle {
  margin-top: 2px;
  font-size: 0.76rem;
  color: rgba(221, 230, 243, 0.62);
}

.gs-app-nav__links {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 10px;
}

.gs-app-nav__link,
.gs-breadcrumbs__link {
  color: rgba(221, 230, 243, 0.78);
  text-decoration: none;
}

.gs-app-nav__link {
  padding: 10px 14px;
  border: 1px solid rgba(159, 192, 255, 0.12);
  background: rgba(9, 15, 24, 0.62);
  font-size: 0.82rem;
  font-weight: 700;
  transition:
    transform 0.18s ease,
    border-color 0.18s ease,
    background 0.18s ease;
}

.gs-app-nav__link:hover,
.gs-app-nav__link.is-active {
  transform: translateY(-1px);
  border-color: rgba(125, 179, 255, 0.36);
  background: rgba(125, 179, 255, 0.12);
}

.gs-breadcrumbs {
  display: flex;
  align-items: center;
  gap: 8px;
  padding-bottom: 4px;
  font-size: 0.8rem;
  color: rgba(221, 230, 243, 0.54);
}

.gs-breadcrumbs__separator {
  color: rgba(221, 230, 243, 0.32);
}

.gs-breadcrumbs__current {
  color: #f6c978;
}

.gs-route-transition {
  animation: gs-page-fade 0.28s ease both;
}

.gs-route-loading {
  width: min(1200px, calc(100vw - 32px));
  margin: 18px auto 0;
  padding: 22px 24px;
  border: 1px solid rgba(159, 192, 255, 0.14);
  background: rgba(9, 15, 24, 0.78);
  color: #dde6f3;
}

.gs-shell {
  /* OpenClaw-inspired default theme */
  --gs-accent-primary: #ff5c5c;
  --gs-accent-primary-rgb: 255, 92, 92;
  --gs-accent-secondary: #14b8a6;
  --gs-accent-secondary-rgb: 20, 184, 166;
  --gs-accent-tertiary: #22c55e;
  --gs-accent-tertiary-rgb: 34, 197, 94;
  --gs-accent-danger: #ef4444;
  --gs-accent-danger-rgb: 239, 68, 68;
  position: relative;
  min-height: 100vh;
  overflow: clip;
  background:
    radial-gradient(circle at top left, rgba(var(--gs-accent-secondary-rgb), 0.12), transparent 28%),
    radial-gradient(circle at 85% 18%, rgba(var(--gs-accent-primary-rgb), 0.14), transparent 32%),
    linear-gradient(180deg, #12141a 0%, #1a1d25 45%, #0d0f14 100%);
}

.gs-shell[data-theme='ember'] {
  --gs-accent-primary: #f97316;
  --gs-accent-primary-rgb: 249, 115, 22;
  --gs-accent-secondary: #fbbf24;
  --gs-accent-secondary-rgb: 251, 191, 36;
  --gs-accent-tertiary: #fb923c;
  --gs-accent-tertiary-rgb: 251, 146, 60;
  --gs-accent-danger: #ef4444;
  --gs-accent-danger-rgb: 239, 68, 68;
}

.gs-shell[data-theme='circuit'] {
  --gs-accent-primary: #14b8a6;
  --gs-accent-primary-rgb: 20, 184, 166;
  --gs-accent-secondary: #22d3ee;
  --gs-accent-secondary-rgb: 34, 211, 238;
  --gs-accent-tertiary: #06b6d4;
  --gs-accent-tertiary-rgb: 6, 182, 212;
  --gs-accent-danger: #ef4444;
  --gs-accent-danger-rgb: 239, 68, 68;
}

.gs-shell::before,
.gs-shell::after {
  content: '';
  position: fixed;
  inset: auto;
  width: 34rem;
  height: 34rem;
  border-radius: 0;
  filter: blur(90px);
  pointer-events: none;
  opacity: 0.45;
  z-index: 0;
}

.gs-shell::before {
  top: -12rem;
  left: -10rem;
  background: rgba(var(--gs-accent-secondary-rgb), 0.16);
}

.gs-shell::after {
  right: -12rem;
  top: 14rem;
  background: rgba(var(--gs-accent-primary-rgb), 0.14);
}

.gs-page {
  position: relative;
  z-index: 1;
  width: min(1200px, calc(100vw - 32px));
  margin: 0 auto;
  padding: 28px 0 80px;
}

.gs-hero,
.gs-demo-section,
.gs-case-study,
.gs-docs-section {
  animation: gs-rise 0.7s ease both;
}

.gs-hero {
  display: grid;
  grid-template-columns: minmax(0, 1.25fr) minmax(320px, 0.9fr);
  gap: 24px;
  align-items: stretch;
  padding: 32px 32px 20px;
}

.gs-hero-copy,
.gs-demo-copy
.gs-docs-copy {
  padding: 28px;
  border: 2px solid rgba(159, 192, 255, 0.2);
  background:
    linear-gradient(180deg, rgba(11, 20, 34, 0.92), rgba(10, 18, 28, 0.74)),
    linear-gradient(135deg, rgba(255, 255, 255, 0.02), transparent 60%);
  box-shadow: 3px 3px 0 rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(14px);
}

.gs-kicker,
.gs-section-kicker {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.74rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--gs-accent-secondary);
}

.gs-kicker::before,
.gs-section-kicker::before {
  content: '';
  width: 1.9rem;
  height: 1px;
  background: currentColor;
}

.gs-hero h1,
.gs-demo-copy h2,
.gs-case-study h2,
.gs-docs-copy h2 {
  margin-top: 12px;
  font-family: 'IBM Plex Sans', -apple-system, sans-serif;
  font-size: clamp(1.8rem, 2.5vw, 2.5rem);
  line-height: 1.2;
  letter-spacing: -0.02em;
  color: #f4f6fb;
  font-weight: 600;
}

.gs-demo-copy h2,
.gs-case-study h2,
.gs-docs-copy h2 {
  font-size: clamp(2rem, 4vw, 3.2rem);
}

.gs-hero-copy > p,
.gs-demo-copy > p,
.gs-docs-copy > p {
  margin-top: 18px;
  max-width: 40rem;
  font-size: 1.04rem;
  line-height: 1.72;
  color: rgba(226, 233, 245, 0.84);
}

.gs-hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 26px;
}

.gs-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 46px;
  padding: 0 18px;
  border: 2px solid transparent;
  border-radius: 0;
  font-size: 0.94rem;
  font-weight: 700;
  text-decoration: none;
  transition:
    transform 0.15s ease,
    border-color 0.15s ease,
    background 0.15s ease,
    box-shadow: 3px 3px 0 rgba(0, 0, 0, 0.4);
}
.gs-button:hover {
  transform: translate(-2px, -1px);
  box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.3);
}
.gs-button--primary {
  color: #fafafa;
  background: var(--gs-accent-primary);
  border-color: var(--gs-accent-primary);
}
.gs-button--secondary {
  color: #e2e9f5;
  border-color: rgba(var(--gs-accent-secondary-rgb), 0.4);
  background: rgba(var(--gs-accent-secondary-rgb), 0.12);
}

.gs-pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 26px;
}

.gs-pill-row span {
  padding: 8px 12px;
  border: 1px solid rgba(159, 192, 255, 0.18);
  background: rgba(12, 20, 31, 0.72);
  font-size: 0.83rem;
  color: rgba(229, 235, 246, 0.86);
}

.gs-route-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
  margin-top: 20px;
}

.gs-route-grid--compact {
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 18px;
}

.gs-route-card {
  display: grid;
  gap: 8px;
  padding: 16px 18px;
  border: 2px solid rgba(159, 192, 255, 0.2);
  background: rgba(12, 18, 28, 0.88);
  color: #dde6f3;
  text-decoration: none;
  transition: transform 0.12s ease, border-color 0.12s ease, background 0.12s ease;
}

.gs-route-card:hover {
  transform: translateY(-2px);
  border-color: var(--gs-accent-primary);
  background: rgba(16, 24, 36, 0.92);
}

.gs-route-card__eyebrow {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #7db3ff;
}

.gs-route-card strong {
  color: #f4f6fb;
  font-size: 1.04rem;
}

.gs-route-card p {
  margin: 0;
  color: rgba(221, 230, 243, 0.68);
  line-height: 1.55;
}

.gs-surface-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18px;
  margin-top: 18px;
}

.gs-surface-card,
.gs-side-card,
.gs-case-card,
.gs-code-card {
  position: relative;
  overflow: hidden;
  padding: 22px;
  border: 2px solid rgba(159, 192, 255, 0.18);
  background: rgba(12, 18, 28, 0.9);
  box-shadow: 3px 3px 0 rgba(0, 0, 0, 0.3);
}

.gs-surface-card--featured {
  grid-column: span 2;
  background:
    radial-gradient(circle at top right, rgba(255, 205, 115, 0.15), transparent 28%),
    linear-gradient(180deg, rgba(16, 29, 45, 0.96), rgba(7, 12, 21, 0.82));
}

.gs-surface-card__eyebrow,
.gs-case-card__eyebrow,
.gs-side-card__eyebrow {
  font-size: 0.74rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--gs-accent-primary);
}

.gs-surface-card h3,
.gs-case-card h3,
.gs-side-card h3 {
  margin-top: 10px;
  font-family: 'Azeret Mono', 'IBM Plex Sans', 'SFMono-Regular', monospace;
  font-size: 1.3rem;
  line-height: 1.15;
  color: #f4f6fb;
}

.gs-surface-card p,
.gs-case-card p,
.gs-side-card p {
  margin-top: 12px;
  font-size: 0.95rem;
  line-height: 1.65;
  color: rgba(226, 233, 245, 0.8);
}

.gs-surface-card__note {
  margin-top: 16px;
  padding-top: 14px;
  border-top: 1px solid rgba(159, 192, 255, 0.12);
  font-size: 0.84rem;
  color: var(--gs-accent-secondary);
}

.gs-demo-section,
.gs-case-study,
.gs-docs-section {
  margin-top: 24px;
}

.gs-demo-layout,
.gs-docs-layout {
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.75fr);
  gap: 18px;
  margin-top: 18px;
}

.gs-demo-stage {
  height: clamp(430px, 72vh, 780px);
  border: 1px solid rgba(159, 192, 255, 0.14);
  background: rgba(7, 12, 21, 0.84);
  box-shadow: 0 28px 80px rgba(0, 0, 0, 0.3);
}

.gs-side-stack,
.gs-case-grid {
  display: grid;
  gap: 18px;
}

.gs-side-list,
.gs-doc-list {
  margin-top: 12px;
  display: grid;
  gap: 10px;
  padding-left: 18px;
  color: rgba(226, 233, 245, 0.82);
}

.gs-side-list li,
.gs-doc-list li {
  line-height: 1.6;
}

.gs-live-roster {
  display: grid;
  gap: 10px;
  margin-top: 16px;
}

.gs-live-roster__row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 10px;
  align-items: center;
  padding: 10px 12px;
  border: 1px solid rgba(159, 192, 255, 0.12);
  background: rgba(16, 24, 36, 0.72);
}

.gs-live-roster__meta {
  display: flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
}

.gs-live-roster__dot {
  width: 8px;
  height: 8px;
  border-radius: 0;
  flex: none;
}

.gs-live-roster__name {
  font-weight: 700;
  color: #f4f6fb;
}

.gs-live-roster__zone {
  color: #90a5c1;
  font-size: 0.82rem;
}

.gs-live-roster__window {
  color: #f6c978;
  font-size: 0.82rem;
  text-align: right;
}

.gs-case-grid {
  margin-top: 18px;
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.gs-docs-layout {
  margin-top: 18px;
}

.gs-code-card pre {
  white-space: pre-wrap;
  word-break: break-word;
  margin: 0;
  font-family: 'Azeret Mono', 'SFMono-Regular', monospace;
  font-size: 0.88rem;
  line-height: 1.7;
  color: #dfe7f3;
}

.gs-code-card code,
.gs-doc-list code,
.gs-docs-copy code,
.gs-summary-card__body code {
  font-family: 'Azeret Mono', 'SFMono-Regular', monospace;
}

.gs-live-stage {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.gs-stage-topbar {
  position: absolute;
  top: 14px;
  left: 14px;
  right: 80px;
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  z-index: 100;
}

.gs-stage-panel {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 38px;
  padding: 0 12px;
  border: 1px solid rgba(159, 192, 255, 0.18);
  background: rgba(9, 15, 24, 0.84);
  color: #dde6f3;
  backdrop-filter: blur(10px);
  transition:
    transform 0.18s ease,
    border-color 0.18s ease,
    background 0.18s ease;
}

.gs-stage-panel:hover {
  transform: translateY(-1px);
}

.gs-stage-panel strong {
  font-size: 1rem;
}

.gs-stage-panel--brand {
  font-family: 'Azeret Mono', 'SFMono-Regular', monospace;
  letter-spacing: 0.12em;
  color: #7db3ff;
}

.gs-stage-panel--stats {
  gap: 12px;
  font-size: 0.85rem;
}

.gs-stage-panel--button {
  cursor: pointer;
  font-weight: 700;
}

.gs-stage-panel--button.is-active {
  border-color: rgba(125, 179, 255, 0.52);
  background: rgba(125, 179, 255, 0.14);
}

.gs-stage-status-dot {
  width: 8px;
  height: 8px;
  border-radius: 0;
}

.gs-stage-panel__error {
  color: #ff9f9f;
  font-size: 0.74rem;
}

.gs-stage-zoom {
  position: absolute;
  top: 14px;
  right: 14px;
  display: grid;
  gap: 6px;
  z-index: 110;
}

.gs-stage-zoom button,
.gs-stage-zoom span {
  display: grid;
  place-items: center;
  width: 38px;
  height: 38px;
  border: 1px solid rgba(159, 192, 255, 0.18);
  background: rgba(9, 15, 24, 0.84);
  color: #dde6f3;
  backdrop-filter: blur(10px);
}

.gs-stage-zoom button {
  cursor: pointer;
  font-size: 1.1rem;
}

.gs-stage-zoom span {
  font-size: 0.8rem;
  color: #f6c978;
}

.gs-stage-heatmap-legend {
  position: absolute;
  left: 14px;
  bottom: 14px;
  z-index: 112;
  max-width: min(360px, calc(100% - 28px));
  padding: 10px 12px;
  border: 1px solid rgba(125, 179, 255, 0.2);
  background: linear-gradient(180deg, rgba(10, 18, 28, 0.88), rgba(7, 12, 21, 0.8));
  backdrop-filter: blur(10px);
  animation: gs-rise 0.28s ease both;
}

.gs-stage-heatmap-legend__eyebrow {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: #7db3ff;
}

.gs-stage-heatmap-legend__body {
  display: flex;
  flex-wrap: wrap;
  gap: 8px 10px;
  margin-top: 8px;
  font-size: 0.78rem;
  color: rgba(221, 230, 243, 0.76);
}

.gs-stage-help,
.gs-stage-roster {
  position: absolute;
  z-index: 100;
  backdrop-filter: blur(10px);
}

.gs-stage-help {
  top: 246px;
  left: 14px;
  max-width: min(480px, calc(100% - 120px));
  padding: 10px 12px;
  border: 1px solid rgba(159, 192, 255, 0.14);
  background: rgba(9, 15, 24, 0.78);
  font-size: 0.78rem;
  line-height: 1.5;
  color: rgba(220, 230, 243, 0.74);
}

.gs-stage-roster {
  right: 14px;
  bottom: 14px;
  width: min(270px, calc(100vw - 28px));
  padding: 12px;
  border: 1px solid rgba(159, 192, 255, 0.14);
  background: rgba(9, 15, 24, 0.8);
}

.gs-stage-roster__label {
  margin-bottom: 8px;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #7db3ff;
}

.gs-stage-roster__item {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  align-items: center;
  gap: 8px;
  width: 100%;
  padding: 8px 0;
  border: 0;
  border-bottom: 1px solid rgba(159, 192, 255, 0.08);
  background: transparent;
  color: #dde6f3;
  text-align: left;
  cursor: pointer;
}

.gs-stage-roster__item:last-of-type {
  border-bottom: 0;
}

.gs-stage-roster__item.is-selected {
  color: #f6c978;
}

.gs-stage-roster__dot {
  width: 7px;
  height: 7px;
  border-radius: 0;
}

.gs-stage-roster__zone {
  color: rgba(221, 230, 243, 0.54);
  font-size: 0.72rem;
}

.gs-stage-roster__more {
  margin-top: 10px;
  font-size: 0.74rem;
  color: rgba(221, 230, 243, 0.54);
}

.gs-agent-hover-card {
  position: absolute;
  width: min(280px, calc(100% - 24px));
  padding: 14px;
  border: 1px solid rgba(125, 179, 255, 0.24);
  border-radius: 0;
  background:
    linear-gradient(180deg, rgba(12, 20, 31, 0.96), rgba(8, 14, 24, 0.92)),
    linear-gradient(135deg, rgba(255, 255, 255, 0.02), transparent 62%);
  box-shadow: 0 18px 48px rgba(0, 0, 0, 0.32);
  backdrop-filter: blur(14px);
  z-index: 155;
  pointer-events: none;
  animation: gs-hover-card-rise 0.18s ease both;
  will-change: transform, top, left;
  transition:
    top 0.18s ease,
    left 0.18s ease,
    border-color 0.18s ease;
}

.gs-agent-hover-card[data-side='left'] {
  transform-origin: right top;
}

.gs-agent-hover-card[data-side='right'] {
  transform-origin: left top;
}

.gs-agent-hover-card[data-vertical='above'] {
  transform-origin: center bottom;
}

.gs-agent-hover-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.gs-agent-hover-card__eyebrow,
.gs-stats-sidebar__section-title,
.gs-agent-hover-card__section-title {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #7db3ff;
}

.gs-agent-hover-card__title {
  margin-top: 4px;
  font-size: 1rem;
  font-weight: 700;
  color: #f4f6fb;
}

.gs-agent-hover-card__status {
  padding: 6px 10px;
  border-radius: 0;
  border: 1px solid rgba(246, 201, 120, 0.34);
  background: rgba(246, 201, 120, 0.12);
  font-size: 0.72rem;
  font-weight: 700;
  color: #f6c978;
  text-transform: uppercase;
}

.gs-agent-hover-card__status.is-live {
  border-color: rgba(155, 255, 180, 0.36);
  background: rgba(155, 255, 180, 0.12);
  color: #9bffb4;
  animation: gs-status-pulse 1.8s ease infinite;
}

.gs-agent-hover-card__grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  margin-top: 14px;
}

.gs-agent-hover-card__grid span,
.gs-agent-hover-card__tool-row span {
  display: block;
  font-size: 0.7rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(221, 230, 243, 0.56);
}

.gs-agent-hover-card__grid strong,
.gs-agent-hover-card__tool-row strong {
  display: block;
  margin-top: 4px;
  font-size: 0.86rem;
  color: #f4f6fb;
}

.gs-agent-hover-card__section {
  margin-top: 14px;
}

.gs-agent-hover-card__tools {
  display: grid;
  gap: 8px;
  margin-top: 10px;
}

.gs-agent-hover-card__tool-row {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 8px;
