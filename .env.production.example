# Copy this file to .env.production for production builds and runtime deployment.
# VITE_PUBLIC_API_BASE is consumed at frontend build time.

# Runtime
BIND_ADDR=0.0.0.0
PORT=3002
STATIC_DIR=/app/dist

GATEWAY_URL=wss://gateway.example.com/ws
GATEWAY_TOKEN=replace-with-gateway-token
GATEWAY_CONFIG_PATH=
GATEWAY_ORIGIN=

GHOST_SHIFT_INSTANCE_ID=ghost-shift-production
GHOST_SHIFT_USER_AGENT=ghost-shift-server/0.1.0
GHOST_SHIFT_VERSION=0.1.0
DEVICE_IDENTITY_PATH=/home/ghostshift/.config/ghost-shift/device-identity.json
PUBLIC_ID_SALT=replace-with-public-id-salt
PUBLIC_HISTORY_PATH=/home/ghostshift/.config/ghost-shift/public-history.jsonl
PUBLIC_HISTORY_RETENTION_HOURS=24
PUBLIC_HISTORY_INTERVAL_SECONDS=30
REDIS_URL=
CACHE_TTL_SECONDS=5
CACHE_MEMORY_MAX_ENTRIES=512
CACHE_WARM_ON_STARTUP=false
LOG_LEVEL=info
REQUEST_SLOW_THRESHOLD_MS=250
GHOST_SHIFT_EMBED_ALLOWED_ORIGINS=

ENABLE_INTERNAL_API=false
INTERNAL_API_TOKEN=

# Build-time frontend override.
# Leave empty for root deployment. Set /office/api when you publish under /office/.
VITE_PUBLIC_API_BASE=
